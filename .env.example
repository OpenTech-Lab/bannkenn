# Copy this file to .env and replace the placeholders before running setup scripts.
# Keep real deployment-specific values only in .env.

# Public IP or hostname operators and agents will use to reach this server.
BANNKENN_PUBLIC_ADDRESS=203.0.113.10

# Space-separated SAN entries for self-signed certificate generation.
# Include every IP/hostname agents or browsers will use.
BANNKENN_TLS_SANS="203.0.113.10 localhost 127.0.0.1"

# Default output directory for bannkenn.crt and bannkenn.key.
BANNKENN_TLS_DIR=/etc/bannkenn/tls

# Dashboard helper defaults.
BANNKENN_LOCAL_BIND=127.0.0.1:3023
BANNKENN_HTTP_DASHBOARD_URL=http://127.0.0.1:3022
BANNKENN_TLS_DASHBOARD_URL=http://127.0.0.1:3023

# Optional version override for agent installation/update helpers.
BANNKENN_VERSION=latest
